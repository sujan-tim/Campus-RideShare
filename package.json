{
  "name": "ruride",
  "version": "1.0.0",
  "private": true,
  "description": "RUride — Rutgers University Verified Campus Rideshare",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "mobile:assets": "npx @capacitor/assets generate --ios --android --iconBackgroundColor '#CC0033' --splashBackgroundColor '#FFF7ED' --logoSplashScale 0.18",
    "mobile:sync": "npm run build && npx cap sync",
    "mobile:ios": "npx cap open ios",
    "mobile:android": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.0",
    "@capacitor/core": "^7.6.0",
    "@capacitor/ios": "^7.6.0",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.6.0",
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.0"
  }
}
